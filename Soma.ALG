algoritmo "Meu Nome"
var
     Numero1, Numero2, S: inteiro
inicio

     Escreval ("Digite um número: ")
        Leia (Numero1)
     Escreval ("Digite um outro número:")
         Leia (Numero2)
         
     S <- (Numero1 + Numero2)
     
     Escreval ("O resultado da soma é: ", S)

fimalgoritmo